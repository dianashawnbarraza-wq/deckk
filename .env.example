# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (order confirmation emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@deckk.me

# Upstash (checkout rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenAI (smart compose — flyer parsing, image descriptions)
OPENAI_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Temporary: skip login for testing (set to true on Vercel only while testing)
BYPASS_AUTH=false
BYPASS_AUTH_EMAIL=demo@deckk.me
BYPASS_AUTH_HANDLE=shawn

# Platform fee in basis points (default 0 = deckk.me charges 0% per PRD §11)
PLATFORM_FEE_BPS=0
